{
  "$schema": "https://github.com/longbridge/gpui-component/raw/refs/heads/main/.theme-schema.json",
  "name": "Catppuccin",
  "author": "Catppuccin",
  "url": "https://github.com/catppuccin/catppuccin",
  "themes": [
    {
      "is_default": false,
      "name": "Catppuccin Mocha",
      "mode": "dark",
      "colors": {
        "background": "#1e1e2e",
        "foreground": "#cdd6f4",
        "border": "#45475a",
        "ring": "#89b4fa",
        "caret": "#f5e0dc",
        "selection.background": "#585b70",
        "overlay": "#11111bcc",
        "window.border": "#45475a",

        "accent.background": "#313244",
        "accent.foreground": "#cdd6f4",
        "muted.background": "#313244",
        "muted.foreground": "#a6adc8",

        "primary.background": "#89b4fa",
        "primary.foreground": "#1e1e2e",
        "primary.active.background": "#74c7ec",
        "primary.hover.background": "#b4befe",

        "secondary.background": "#45475a",
        "secondary.foreground": "#cdd6f4",
        "secondary.active.background": "#585b70",
        "secondary.hover.background": "#585b70",

        "danger.background": "#f38ba8",
        "danger.foreground": "#1e1e2e",
        "success.background": "#a6e3a1",
        "success.foreground": "#1e1e2e",
        "warning.background": "#f9e2af",
        "warning.foreground": "#1e1e2e",
        "info.background": "#74c7ec",
        "info.foreground": "#1e1e2e",

        "popover.background": "#181825",
        "popover.foreground": "#cdd6f4",
        "title_bar.background": "#181825",
        "title_bar.border": "#45475a",

        "tab_bar.background": "#313244",
        "tab_bar.segmented.background": "#313244",
        "tab.background": "#313244",
        "tab.foreground": "#a6adc8",
        "tab.active.background": "#1e1e2e",
        "tab.active.foreground": "#cdd6f4",

        "sidebar.background": "#181825",
        "sidebar.foreground": "#cdd6f4",
        "sidebar.border": "#45475a",
        "sidebar.accent.background": "#313244",
        "sidebar.accent.foreground": "#cdd6f4",
        "sidebar.primary.background": "#89b4fa",
        "sidebar.primary.foreground": "#1e1e2e",

        "input.border": "#45475a",
        "switch.background": "#45475a",
        "slider.bar.background": "#89b4fa",
        "slider.thumb.background": "#cdd6f4",
        "progress_bar.background": "#89b4fa",
        "skeleton.background": "#313244",
        "drag_border": "#89b4fa",
        "drop_target.background": "#89b4fa40",

        "scrollbar.background": "#1e1e2e00",
        "scrollbar.thumb.background": "#585b70cc",
        "scrollbar.thumb.hover.background": "#6c7086",

        "list.background": "#1e1e2e",
        "list.active.background": "#313244",
        "list.active.border": "#89b4fa",
        "list.even.background": "#181825",
        "list.head.background": "#181825",
        "list.hover.background": "#313244",

        "table.background": "#1e1e2e",
        "table.active.background": "#313244",
        "table.active.border": "#89b4fa",
        "table.even.background": "#181825",
        "table.head.background": "#181825",
        "table.head.foreground": "#a6adc8",
        "table.hover.background": "#313244",
        "table.row.border": "#313244",

        "accordion.background": "#1e1e2e",
        "group_box.background": "#181825",
        "group_box.foreground": "#cdd6f4",
        "link.foreground": "#89b4fa",
        "link.active.foreground": "#74c7ec",
        "link.hover.foreground": "#b4befe",
        "tiles.background": "#181825",
        "description_list_label.background": "#181825",
        "description_list_label.foreground": "#cdd6f4",

        "chart_1": "#89b4fa",
        "chart_2": "#74c7ec",
        "chart_3": "#cba6f7",
        "chart_4": "#94e2d5",
        "chart_5": "#f9e2af",
        "chart_bullish": "#a6e3a1",
        "chart_bearish": "#f38ba8",

        "base.red": "#f38ba8",
        "base.red.light": "#eba0ac",
        "base.green": "#a6e3a1",
        "base.green.light": "#b9e8b3",
        "base.yellow": "#f9e2af",
        "base.yellow.light": "#fbecc5",
        "base.blue": "#89b4fa",
        "base.blue.light": "#b4befe",
        "base.magenta": "#cba6f7",
        "base.magenta.light": "#dcc3fa",
        "base.cyan": "#94e2d5",
        "base.cyan.light": "#b3ebe1"
      },
      "highlight": {
        "editor.foreground": "#cdd6f4",
        "editor.background": "#1e1e2e",
        "editor.active_line.background": "#313244aa",
        "editor.line_number": "#a6adc8",
        "editor.active_line_number": "#cdd6f4",
        "editor.invisible": "#585b7066",
        "conflict": "#f38ba8",
        "created": "#a6e3a1",
        "deleted": "#f38ba8",
        "error": "#f38ba8",
        "hidden": "#a6adc8",
        "hint": "#89b4fa",
        "ignored": "#a6adc8",
        "info": "#74c7ec",
        "modified": "#f9e2af",
        "predictive": "#a6adc8",
        "renamed": "#cba6f7",
        "success": "#a6e3a1",
        "unreachable": "#a6adc8",
        "warning": "#f9e2af",
        "syntax": {
          "attribute": { "color": "#f9e2af" },
          "boolean": { "color": "#f5c2e7" },
          "comment": { "color": "#6c7086", "font_style": "italic" },
          "comment.doc": { "color": "#6c7086", "font_style": "italic" },
          "constant": { "color": "#f9e2af" },
          "constructor": { "color": "#89b4fa" },
          "embedded": { "color": "#cdd6f4" },
          "function": { "color": "#89b4fa" },
          "keyword": { "color": "#f5c2e7" },
          "link_text": { "color": "#89b4fa", "font_style": "normal" },
          "link_uri": { "color": "#6c7086", "font_style": "italic" },
          "number": { "color": "#f9e2af" },
          "string": { "color": "#a6e3a1" },
          "string.escape": { "color": "#a6e3a1" },
          "string.regex": { "color": "#a6e3a1" },
          "string.special": { "color": "#f9e2af" },
          "string.special.symbol": { "color": "#f9e2af" },
          "tag": { "color": "#89b4fa" },
          "text.literal": { "color": "#cdd6f4" },
          "title": { "color": "#f5c2e7", "font_weight": 600 },
          "type": { "color": "#89b4fa" },
          "property": { "color": "#cdd6f4" },
          "variable.special": { "color": "#f5c2e7" }
        }
      }
    }
  ]
}
