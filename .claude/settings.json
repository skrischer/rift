{
  "permissions": {
    "allow": ["Bash", "WebFetch", "WebSearch"],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f)",
      "Bash(git clean -f *)",
      "Bash(git branch -D *)",
      "Bash(cargo clean)",
      "Bash(cargo clean *)",
      "Bash(tmux kill-server)",
      "Bash(tmux kill-server *)",
      "Bash(tmux kill-session)",
      "Bash(tmux kill-session *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/developer/.claude/scripts/guard-protected-branches.sh",
            "if": "Bash(git push*)"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "loopkit@loopkit": true
  }
}
