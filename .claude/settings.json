{
  "permissions": {
    "allow": [
      "Bash(cargo *)",
      "Bash(just *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git fetch*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git stash*)",
      "Bash(gh pr *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/developer/.claude/scripts/guard-protected-branches.sh",
            "if": "Bash(git push*)"
          }
        ]
      }
    ]
  }
}
